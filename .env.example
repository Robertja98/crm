# Example environment file for CRM
# Copy to .env and fill in your values
DB_HOST=localhost
DB_NAME=crmdb
DB_USER=admin
DB_PASSWORD=changeme
PROD_DB_HOST=localhost
PROD_DB_NAME=crmdb1
PROD_DB_USER=crm_admin
PROD_DB_PASSWORD=changeme
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
BACKUP_RETENTION_COUNT=50
AUDIT_BACKUP_DIR=backups/audit/

# Outlook SMTP settings for mass_email.php
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=your_outlook_email@outlook.com
SMTP_PASSWORD=your_outlook_app_password_or_account_password
SMTP_ENCRYPTION=tls
